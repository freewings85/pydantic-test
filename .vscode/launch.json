      "justMyCode": false
    },
    {
      "name": "Interrupt: 发起方 (等待审核)",
      "type": "debugpy",
      "request": "launch",
      "program": "test_interrupt_demo.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Interrupt: 审核通过",
      "type": "debugpy",
      "request": "launch",
      "program": "test_interrupt_resume.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Interrupt: 审核拒绝",
      "type": "debugpy",
      "request": "launch",
      "program": "test_interrupt_resume.py",
      "args": [
        "reject"
