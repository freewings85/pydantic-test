{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Python: main.py",
      "type": "debugpy",
      "request": "launch",
      "program": "main.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Temporal: Worker + Workflow (等待审批)",
      "type": "debugpy",
      "request": "launch",
      "program": "test_temporal_interrupt.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Temporal: 发送审批 (通过)",
      "type": "debugpy",
      "request": "launch",
      "program": "test_temporal_signal.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Temporal: 发送审批 (拒绝)",
      "type": "debugpy",
      "request": "launch",
      "program": "test_temporal_signal.py",
      "args": [
        "reject"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Temporal: 基础示例",
      "type": "debugpy",
      "request": "launch",
